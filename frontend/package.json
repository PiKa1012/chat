{
  "name": "my-chat-app-frontend",
  "version": "1.0.0",
  "main": "src/main.js",
  "scripts": {
    "dev:vite": "vite",
    "dev:electron": "set NODE_ENV=development&& electron .",
    "dev": "concurrently \"npm run dev:vite\" \"wait-on http://localhost:5173 && npm run dev:electron\"",
    "build:vite": "vite build",
    "build:electron": "npm run build:vite && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "socket.io-client": "^4.8.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.2.1",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "vite": "^5.4.11",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.mychat.app",
    "productName": "MyChat",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "files": [
      "dist/**/*",
      "src/main.js",
      "src/preload.js"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico",
      "sign": null,
      "signingHashAlgorithms": null
    }
  }
}